{
  "manifest_version": 3,
  "name": "Jira Bug Reporter",
  "version": "1.2.0",
  "minimum_chrome_version": "116",
  "description": "Aktif sayfadan hata ve ağ bilgilerini toplayıp Jira'da bilet açar.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jira Bug Reporter"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+J"
      },
      "description": "Jira Bug Reporter penceresini aç"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
